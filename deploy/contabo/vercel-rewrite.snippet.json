{
  "redirects": [
    {
      "source": "/mpesa-scorer",
      "destination": "/mpesa-scorer/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/mpesa-scorer/",
      "destination": "http://169.58.16.179/"
    },
    {
      "source": "/mpesa-scorer/:path*",
