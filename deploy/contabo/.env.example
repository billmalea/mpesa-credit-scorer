# DNS must point scorer.ttacs.co.ke to the Contabo VPS before Caddy can obtain TLS.
CADDY_EMAIL=ops@ttacs.co.ke

# Use a long unique value; it configures FlexVertex and the scorer's audit client.
FLEXVERTEX_PASSWORD=replace-with-a-long-random-password
# Leave blank to reuse FLEXVERTEX_PASSWORD.
FLEXVERTEX_UNDERWRITER_PASSWORD=

# Required for the public scorer. Format: username:long-random-password
SCORER_BASIC_AUTH=ttacs:replace-with-a-second-long-random-password
